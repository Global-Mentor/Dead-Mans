{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost --port 5180 --strictPort",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:locales": "node scripts/check-locale-keys.mjs",
    "knip": "knip",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm run check:locales && npm run test && npm run knip && npm run build",
    "generate:contracts": "openapi-typescript ../backend/openapi/deadmans.v1.yaml -o src/shared/api/contracts/generated.ts",
    "generate:realtime": "node scripts/generate-realtime-contracts.mjs",
    "generate:transport": "npm run generate:contracts && npm run generate:realtime",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@microsoft/signalr": "^10.0.0",
    "@mui/material": "^7.3.5",
    "@mui/system": "^7.3.5",
    "@tanstack/react-query": "^5.90.11",
    "i18next": "^25.7.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^16.3.5",
    "react-router-dom": "^7.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "baseline-browser-mapping": "^2.10.34",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "knip": "^5.30.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.8",
    "yaml": "^2.8.1"
  }
}
