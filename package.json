{
  "name": "dead-mans",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:ps": "docker compose ps",
    "docker:logs": "docker compose logs -f",
    "dev:backend": "dotnet run --project backend/backend.csproj",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "dotnet build backend/backend.slnx",
    "build:frontend": "npm --prefix frontend run build",
    "generate:contracts": "npm --prefix frontend run generate:contracts",
    "test": "dotnet test backend/backend.slnx"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
