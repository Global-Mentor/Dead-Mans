{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5180",
      "https://localhost:5180"
    ]
  },
  "TwitchAuth": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5285/auth/twitch/callback",
    "FrontendRedirectUri": "http://localhost:5180/auth/callback",
    "Scopes": [
      "openid",
      "user:read:email"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Storage": {
    "PublicBaseUrl": "http://localhost:9000"
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "TrustedProxies": [],
    "TrustedNetworks": [],
    "TrustAllProxiesInDevelopment": true
  }
}
